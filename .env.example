SPREADSHEET_ID=your_spreadsheet_id_here
GOOGLE_APPLICATION_CREDENTIALS=./google-credentials.json
PORT=8080

# OAuth 2.0 (Google) — para Gmail + Sheets con consentimiento del usuario
# OAUTH_REDIRECT_URI debe coincidir con el URI configurado en Google Console y con tu PORT
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
OAUTH_REDIRECT_URI=http://localhost:8080/api/auth/google/callback
